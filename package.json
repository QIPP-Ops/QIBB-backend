{
  "name": "qipp-backend",
  "version": "1.0.0",
  "description": "QIPP operational data API (Express + MongoDB Atlas)",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "seed:mongodb": "node scripts/seed-mongodb.js",
    "seed:super-admin": "node scripts/seed-super-admin.js",
    "seed:employees": "node scripts/seedEmployeeData.js",
    "seed:qipp-leave-data": "node scripts/seed-qipp-leave-data.js",
    "seed:ptw": "node seeders/ptwSeed.js",
    "seed:quizzes": "node scripts/seed-quizzes.js",
    "import:qipp": "cross-env NODE_OPTIONS=--use-system-ca node scripts/import-qipp-prometheus.js",
    "import:qipp:json": "cross-env NODE_OPTIONS=--use-system-ca node scripts/import-qipp-prometheus.js --json-only",
    "parse:ptw": "node scripts/parse-ptw-excel.js",
    "parse:ops-org": "node scripts/parse-ops-org-chart-html.js",
    "import:ops-org": "node scripts/import-ops-org-chart.js",
    "seed:ops-org-html": "node scripts/seed-ops-org-html.js",
    "build:crew-calendar": "node scripts/build-crew-calendar-seed.js",
    "migrate:employee-external-ids": "node scripts/migrate-employee-external-ids.js",
    "migrate:compensate-leave-types": "node scripts/migrate-compensate-leave-types.js",
    "backup:org-chart": "node scripts/backup-org-chart-data.js",
    "seed:curriculum": "node scripts/seed-curriculum.js",
    "migrate:auth": "node scripts/migrate-auth-fields.js",
    "set-password": "node scripts/set-user-password.js",
    "test": "jest --forceExit --detectOpenHandles"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "axios": "^1.7.7",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1",
    "multer": "^2.1.1",
    "nodemailer": "^6.9.16",
    "resend": "^4.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "xlsx": "^0.18.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.test.js"
    ]
  }
}
