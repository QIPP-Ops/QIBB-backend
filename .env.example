# QIPP migration: MongoDB Atlas + Render backend + GitHub Pages frontend
#
# Copy to .env locally — NEVER commit real credentials.

# ─── MongoDB Atlas ───────────────────────────────────────────────────────────
# Append /QIPP automatically when URI has no database path (see config/database.js)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_DB_NAME=QIPP
# Legacy alias (same value as MONGODB_URI)
# COSMOS_URI=mongodb+srv://...

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend origin (password reset links + CORS)
FRONTEND_URL=https://qipp.live
# Extra CORS origins (comma-separated) — e.g. GitHub Pages without custom domain
# CORS_ORIGINS=https://qipp-ops.github.io,https://qipp-ops.github.io/QIBB-frontend

# ─── Super admin (npm run seed:mongodb) — uses SMTP mailbox by default ───────
# Optional overrides only if you want a different login than the SMTP account:
# SUPER_ADMIN_EMAIL=
# SUPER_ADMIN_PASSWORD=

# ─── SMTP (OTP, password reset, broadcasts) ──────────────────────────────────
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
SMTP_FROM=QIPP Operations <your-smtp-user@example.com>
# EMAIL_PASS is an alias for SMTP_PASS

# ─── Seed options (npm run seed:mongodb) ─────────────────────────────────────
# SEED_DEFAULT_USER_PASSWORD — optional temp password for roster accounts
# SEED_KPI_DATA=1          — load plant_data.json when PlantPerformance is empty
# SEED_FORCE_RESET=1       — destructive: wipe users/config/KPI before seed
# SEED_ON_STARTUP=0        — do not auto-seed on server boot (run seed manually)

# ─── Azure blob trends (deferred — optional) ─────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=
# BLOB_SAS_URL=
# PLANT_INGEST_ON_STARTUP=0
# TRENDS_BLOBS_DIR=data/trends-blobs
