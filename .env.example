# MongoDB (Cosmos DB API) — use either name (Azure often has MONGODB_URI)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
# COSMOS_URI=mongodb+srv://...   (same as MONGODB_URI)

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# Server
PORT=5000
NODE_ENV=development

# Frontend (password reset links, CORS). Use full URL or domain only (https added automatically).
# Production example: FRONTEND_URL=https://qipp.live
FRONTEND_URL=http://localhost:3000

# Optional — only for npm run seed (local dev)
# SEED_ADMIN_EMAIL=your-admin@your-company.com

# Super admin (admin@acwaops.com by default) — npm run seed:super-admin
# SUPER_ADMIN_EMAIL=admin@acwaops.com
# SUPER_ADMIN_PASSWORD=choose-a-strong-password

# SMTP (OTP, password reset emails)
# --- Azure App Service (qipp-api) — GoDaddy mailbox example ---
# SMTP_HOST=smtpout.secureserver.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=admin@acwaops.com
# SMTP_PASS=<GoDaddy mailbox password>   OR use EMAIL_PASS (same value)
# EMAIL_USER is an alias for SMTP_USER
# FRONTEND_URL=https://qipp.live
# MONGODB_URI=<cosmos connection string>
# JWT_SECRET=<long random string>
# Test: GET https://qipp-api.azurewebsites.net/health/email?verify=1
SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASS=your-smtp-app-password
# EMAIL_PASS is accepted as an alias for SMTP_PASS (Azure App Settings)

# Plant Excel ingest — Azure Blob container "report" (pipeline lands files here)
# Use container SAS URL (recommended): https://account.blob.core.windows.net/report?sv=...
# Or account connection string (also works):
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
BLOB_SAS_URL=https://acwaopsqipp.blob.core.windows.net/report?<sas-token>
BLOB_STORAGE_ACCOUNT=acwaopsqipp
BLOB_CONTAINER_NAME=report
PLANT_INGEST_ON_STARTUP=1
PLANT_INGEST_MAX_FILES=200
PLANT_INGEST_MAX_AGE_DAYS=365
PLANT_INGEST_INTERVAL_MS=900000
TREND_BACKFILL_MAX_DAYS=365
PLANT_INGEST_MAX_FILES=800
TREND_BACKFILL_MAX_DAYS=120
TREND_BACKFILL_MAX_FILES=160

# Optional local dev fallback only (not used when BLOB_SAS_URL is set)
# PLANT_REPORTS_DIR=

# Optional — legacy SharePoint trends sync
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=
# SHAREPOINT_SITE_ID=
# SHAREPOINT_DRIVE_ID=

# Optional — ETL (Python scripts use COSMOS_MONGO_URI or same value as COSMOS_URI)
# COSMOS_DB_NAME=qipp_ops
