{
  "kpis": {
    "gn": {
      "label": "Gross Generation",
      "unit": "MWh",
      "keys": ["daily_op_plant_gross_gen_mwh", "plant_generation", "generation", "gross_generation", "gen"],
      "patterns": ["daily_op_plant_gross_gen", "plant_generation", "gross.*gen", "generation.*mwh"]
    },
    "ld": {
      "label": "Plant Load",
      "unit": "MW",
      "keys": ["daily_op_total_plant_load_mw", "plant_total_load", "load", "plant_load", "load_mw"],
      "patterns": ["daily_op_total_plant_load", "plant_total_load", "total_plant_load", "load_mw"]
    },
    "pf": {
      "label": "PLF",
      "unit": "%",
      "keys": ["daily_op_plf_pct", "plf", "plant_load_factor"],
      "patterns": ["daily_op_plf", "plf", "plant.*availability", "plant_load_factor"]
    },
    "ef": {
      "label": "Net Efficiency",
      "unit": "%",
      "keys": ["daily_op_net_efficiency_pct", "efficiency", "net_efficiency"],
      "patterns": ["daily_op_net_efficiency", "plant_net_efficiency", "net_efficiency", "net.*efficien"]
    },
    "hr": {
      "label": "Heat Rate",
      "unit": "kJ/kWh",
      "keys": ["daily_op_heat_rate_kjkwh", "heat_rate", "heatrate"],
      "patterns": ["daily_op_heat_rate", "plant_heat_rate", "heat_rate", "heatrate"]
    },
    "fu": {
      "label": "Fuel Gas",
      "unit": "T",
      "keys": ["daily_op_fuel_gas_tons", "fuel", "fuel_gas"],
      "patterns": ["daily_op_fuel_gas", "plant_fuel_gas", "fuel_gas"]
    },
    "mf": {
      "label": "MFEQH",
      "unit": "Hrs",
      "keys": ["daily_op_st60_mfeqh_hours", "mfeqh"],
      "patterns": ["daily_op_.*_mfeqh", "mfeqh", "equivalent.*operating.*hours"]
    },
    "nox": {
      "label": "NOx",
      "unit": "mg/Nm³",
      "keys": ["nox", "emissions_nox"],
      "patterns": ["nox", "no_x"]
    },
    "sox": {
      "label": "SOx",
      "unit": "mg/Nm³",
      "keys": ["sox", "so2", "emissions_sox"],
      "patterns": ["sox", "so2", "sulphur"]
    },
    "co": {
      "label": "CO",
      "unit": "mg/Nm³",
      "keys": ["co", "emissions_co"],
      "patterns": ["\\bco\\b", "carbon monoxide"]
    },
    "waterProd": {
      "label": "Water production",
      "unit": "m³",
      "keys": ["ro_production", "dm_production"],
      "patterns": ["ro.*prod", "dm.*prod", "water.*prod", "desal", "migd"]
    }
  },
  "charts": {
    "cT": {
      "label": "Combined trend",
      "keys": [
        "daily_op_plant_gross_gen_mwh",
        "daily_op_total_plant_load_mw",
        "daily_op_plf_pct",
        "daily_op_net_efficiency_pct",
        "daily_op_heat_rate_kjkwh",
        "daily_op_fuel_gas_tons",
        "generation",
        "load",
        "plf",
        "efficiency",
        "heat_rate",
        "fuel",
        "mfeqh"
      ]
    },
    "cHR": {
      "label": "Heat Rate",
      "unit": "kJ/kWh",
      "keys": ["daily_op_heat_rate_kjkwh", "heat_rate", "heatrate"]
    },
    "cEF": {
      "label": "Net Efficiency",
      "unit": "%",
      "keys": ["daily_op_net_efficiency_pct", "efficiency", "net_efficiency"]
    },
    "cPF": {
      "label": "PLF",
      "unit": "%",
      "keys": ["daily_op_plf_pct", "plf", "plant_load_factor"]
    },
    "cMF": {
      "label": "MFEQH",
      "unit": "Hrs",
      "keys": ["daily_op_st60_mfeqh_hours", "mfeqh"]
    },
    "cEM": {
      "label": "Emissions",
      "unit": "mg/Nm³",
      "keys": ["nox", "sox", "so2", "co", "emissions_nox", "emissions_sox", "emissions_co"]
    },
    "cFU": {
      "label": "Fuel Gas",
      "unit": "T",
      "keys": ["daily_op_fuel_gas_tons", "fuel", "fuel_gas"]
    },
    "cUN": {
      "label": "Unit generation",
      "unit": "MWh",
      "keys": ["daily_op_gt11_daily_mwh", "daily_op_st60_daily_mwh", "water", "makeup_water"]
    }
  },
  "management": {
    "monthlyGeneration": {
      "label": "Monthly generation",
      "unit": "MWh",
      "keys": ["daily_op_plant_gross_gen_mwh", "plant_generation"]
    },
    "monthlyPlf": {
      "label": "Monthly PLF",
      "unit": "%",
      "keys": ["daily_op_plf_pct", "plant_load_factor", "plf"]
    }
  },
  "blobs": {
    "daily_ops": "Daily Operations",
    "water": "Water",
    "hrsg": "HRSG Chemistry",
    "fg_filter": "FG Filter DP",
    "air_intake": "Air Intake Filter DP",
    "environment": "Environment"
  }
}
